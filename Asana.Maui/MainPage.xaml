<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Asana.Maui.MainPage"
             NavigatedTo="ContentPage_NavigatedTo"
             NavigatedFrom="ContentPage_NavigatedFrom">

    <Grid Padding="30,0" RowSpacing="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- ToDo List (fills available space) -->
            <RowDefinition Height="Auto"/>
            <!-- Button Bar (always visible) -->
        </Grid.RowDefinitions>

        <!-- Tool Bar -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="0" Text="Show Completed Tasks:"/>
            <CheckBox Margin="5" Grid.Column="1" IsChecked="{Binding IsShowCompleted}"/>
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Entry Grid.Column="0" Text="{Binding Query}"/>
                <Button Grid.Column="1" Text="Search" Clicked="SearchClicked"/>
            </Grid>
        </Grid>

        <!-- ToDo List (scrollable, fills available space) -->
        <ListView
            Grid.Row="1"
            ItemsSource="{Binding ToDos}"
            SelectedItem="{Binding SelectedToDo}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="7*"/>
                                <ColumnDefinition/>
                                
                            <!-- column 0 (checkboxes) definition-->
                            </Grid.ColumnDefinitions>
                            <CheckBox IsChecked="{Binding Model.IsCompleted, Mode=TwoWay}" Grid.Column="0"/>

                            <!-- column 1 (titles) definition-->
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" FontSize="Medium" Text="Project Name:"/>
                                <Label Grid.Row="1" FontSize="Small" Text="Project Description:"/>
                                <Label Grid.Row="2" Text=" Linked to:" FontAttributes="Italic"/>
                                <Label Grid.Row="3" Text="DueDate: " FontSize="Small"/>
                                <Label Grid.Row="4" Text="Priority:" FontAttributes="Bold" FontSize="Small"/>
                            </Grid>

                            <!-- column 2 (context) definition-->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    
                                </Grid.RowDefinitions>
                                <Label TextColor="Fuchsia" Grid.Row="0" FontSize="Medium" Text="{Binding Model.Name}"/>
                                <Label Grid.Row="1" FontSize="Small" Text="{Binding Model.Description}"/>
                                <Label Grid.Row="2" Grid.Column="2"  Text="{Binding ProjectName}"
                                        FontSize="Micro" TextColor="Coral"/>
                                <Label Grid.Row="3" Text="{Binding Model.DueDate}" FontAttributes="Italic" FontSize="Small"/>
                                <Label Grid.Row="4" Text="{Binding Model.Priority}" FontAttributes="Bold" FontSize="Small" TextColor="DarkGreen"/>
                            </Grid>

                            <!-- column 3 (delete button) definition-->
                            <Grid Grid.Column="3">
                                <Button Grid.Column="1" BackgroundColor="IndianRed" Text="Delete" Clicked="InLineDeleteClicked" Command="{Binding DeleteCommand}"/>
                            </Grid>
                            
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Button Bar (always visible at bottom) -->
        <VerticalStackLayout Grid.Row="2">
            <Button Text="Add New ToDo" Clicked="AddNewClicked" BackgroundColor="Coral"/>
            <Button Text="Edit Selected ToDo" Clicked="EditClicked" BackgroundColor="Coral"/>
            <Button Text="Manage Projects" Clicked="ProjectClicked" BackgroundColor="Gold"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>