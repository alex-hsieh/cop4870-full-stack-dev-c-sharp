<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Asana.Maui.Views.ProjectDetailView"
             Title="ProjectDetailView"
             NavigatedFrom="ContentPage_NavigatedFrom"
             NavigatedTo="ContentPage_NavigatedTo">
    <VerticalStackLayout Spacing="20" Padding="20">
        <Grid ColumnDefinitions="Auto,3*">
            <Label Text="Project Id:" Grid.Column="0" VerticalOptions="Center"/>
            <Entry Text="{Binding Model.Id}" Grid.Column="1" IsReadOnly="True"/>
        </Grid>
        <Grid ColumnDefinitions="Auto,3*">
            <Label Text="Project Name:" Grid.Column="0" VerticalOptions="Center"/>
            <Entry Text="{Binding Model.Name}" Grid.Column="1"/>
        </Grid>
        <Grid ColumnDefinitions="Auto,3*">
            <Label Text="Description:" Grid.Column="0" VerticalOptions="Center"/>
            <Entry Text="{Binding Model.Description}" Grid.Column="1"/>
        </Grid>
        <Button Text="Ok" Clicked="OkClicked"/>
        <Button Text="Cancel" Clicked="CancelClicked"/>
    </VerticalStackLayout>
</ContentPage>