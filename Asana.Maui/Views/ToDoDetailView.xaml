<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Asana.Maui.Views.ToDoDetailView"
             Title="ToDo Details"
             NavigatedFrom="ContentPage_NavigatedFrom"
             NavigatedTo="ContentPage_NavigatedTo">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">

            <!-- Header -->
            <Label Text="{Binding Model.Id, StringFormat='Task #{0}'}" 
                   FontSize="Large" 
                   FontAttributes="Bold"
                   IsVisible="{Binding Model.Id, Converter={StaticResource IntToBoolConverter}}" />

            <!-- Task Name -->
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="ToDo Name:" Grid.Column="0" VerticalOptions="Center" FontAttributes="Bold"/>
                <Entry Text="{Binding Model.Name}" 
                       Grid.Column="1" 
                       Placeholder="Enter ToDo name..."
                       Margin="10,0,0,0"/>
            </Grid>

            <!-- Validation Error -->
            <Label Text="{Binding ValidationError}" 
                   TextColor="Red" 
                   FontSize="Small"
                   IsVisible="{Binding ValidationError, Converter={StaticResource StringToBoolConverter}}" />

            <!-- Description -->
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="Description:" Grid.Column="0" VerticalOptions="Start" FontAttributes="Bold" Margin="0,10,0,0"/>
                <Editor Text="{Binding Model.Description}" 
                        Grid.Column="1"
                        Placeholder="Enter ToDo description..."
                        HeightRequest="100"
                        Margin="10,0,0,0"/>
            </Grid>

            <!-- Project Assignment -->
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="Project:" Grid.Column="0" VerticalOptions="Center" FontAttributes="Bold"/>
                <Picker ItemsSource="{Binding AvailableProjects}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedProject}"
                        Grid.Column="1"
                        Title="Select a project..."
                        Margin="10,0,0,0"/>
            </Grid>

            <!-- Priority and Completion Row -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                <!-- Priority -->
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="Priority:" FontAttributes="Bold"/>
                    <Picker ItemsSource="{Binding Priorities}"
                            SelectedItem="{Binding SelectedPriority}"
                            Title="Select priority..."/>
                    
                </VerticalStackLayout>

                <!-- Completion Status -->
                <VerticalStackLayout Grid.Column="1">
                    <Label Text="Status:" FontAttributes="Bold"/>
                    <CheckBox IsChecked="{Binding Model.IsCompleted}" 
                              HorizontalOptions="Start"/>
                    <Label Text="{Binding Model.IsCompleted, Converter={StaticResource BoolToCompletionStatusConverter}}"
                           FontSize="Small"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="3*"/>
                </Grid.ColumnDefinitions>
                <Label Text="Due Date:" Grid.Column="0" VerticalOptions="Center"/>
                <DatePicker Date="{Binding DueDate}" Grid.Column="1"/>
            </Grid>

            <!-- Action Buttons -->
            <VerticalStackLayout Spacing="10" Margin="0,20,0,0">
                <Button Text="Save Task" 
                        Clicked="OkClicked" 
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        IsEnabled="{Binding IsValid}"/>

                <Button Text="Cancel" 
                        Clicked="CancelClicked" 
                        BackgroundColor="{StaticResource Gray300}"
                        TextColor="Black"/>

                <Button Text="Delete Task" 
                        Command="{Binding DeleteCommand}"
                        Clicked="CancelClicked"
                        BackgroundColor="{StaticResource Tertiary}"
                        TextColor="White"
                        IsVisible="{Binding Model.Id, Converter={StaticResource IntToBoolConverter}}"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>